---
---

<section id="sobre" class="about section-padding">
	<div class="container">
		<div class="about-content">
			<div class="about-text">
				<div class="section-header">
					<h2 class="section-title">
						Uma inovação sem<br>
						<span class="gradient-text">precedentes no Brasil</span>
					</h2>
					<p class="section-subtitle">
						A 4Nexus e o P7 Criativo uniram forças para criar um conceito único no país, 
						integrando tecnologia de ponta, interatividade e conteúdo de mídia em um ambiente exclusivo.
					</p>
				</div>

				<div class="about-features">
					<div class="about-feature">
						<div class="feature-icon-large">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M3 21L21 21M5 21V7L13 2L21 7V21M9 9H15M9 13H15M9 17H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<circle cx="13" cy="5" r="1" fill="currentColor"/>
							</svg>
						</div>
						<div class="feature-content">
							<h3>Localização Privilegiada</h3>
							<p>24º andar do icônico edifício P7 Criativo, no centro de Belo Horizonte, com vista panorâmica da cidade.</p>
						</div>
					</div>

					<div class="about-feature">
						<div class="feature-icon-large">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M12.5 7.5C12.5 9.98528 10.4853 12 8 12C5.51472 12 3.5 9.98528 3.5 7.5C3.5 5.01472 5.51472 3 8 3C10.4853 3 12.5 5.01472 12.5 7.5ZM20 8V14M23 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<circle cx="20" cy="11" r="2" stroke="currentColor" stroke-width="1.5"/>
							</svg>
						</div>
						<div class="feature-content">
							<h3>Parceria Estratégica</h3>
							<p>União entre a expertise da 4Nexus em produção audiovisual e a inovação do ecossistema P7 Criativo.</p>
						</div>
					</div>

					<div class="about-feature">
						<div class="feature-icon-large">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M12 2L15.09 8.26L22 9L17 14L18.18 21L12 17.77L5.82 21L7 14L2 9L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<div class="feature-content">
							<h3>Foco na Qualidade</h3>
							<p>Compromisso com excelência em cada projeto, desde podcasts até produções corporativas de grande escala.</p>
						</div>
					</div>
				</div>
			</div>

			<div class="about-visual">
				<div class="stats-grid">
					<div class="stat-card">
						<div class="stat-number">2018</div>
						<div class="stat-label">Fundação da 4Nexus</div>
					</div>
					<div class="stat-card">
						<div class="stat-number">35+</div>
						<div class="stat-label">Anos de Experiência</div>
					</div>
					<div class="stat-card">
						<div class="stat-number">3</div>
						<div class="stat-label">Estados Atendidos</div>
					</div>
					<div class="stat-card highlight">
						<div class="stat-number">100%</div>
						<div class="stat-label">Qualidade Profissional</div>
					</div>
				</div>

				<div class="concept-card">
					<div class="concept-header">
						<div class="concept-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
								<path d="M12 1V3M12 21V23M4.22 4.22L5.64 5.64M18.36 18.36L19.78 19.78M1 12H3M21 12H23M4.22 19.78L5.64 18.36M18.36 5.64L19.78 4.22" stroke="currentColor" stroke-width="2"/>
								<circle cx="12" cy="12" r="2" fill="currentColor"/>
							</svg>
						</div>
						<h4>CONCEITO ÚNICO</h4>
					</div>
					<div class="concept-content">
						<h3>Inovação sem Paralelos</h3>
						<p>O Media Lounge representa um conceito inovador e único no Brasil, integrando tecnologia de ponta, interatividade e conteúdo de mídia em um ambiente exclusivo.</p>
						<p>Este espaço é projetado para oferecer uma experiência imersiva aos visitantes, permitindo interações ricas com conteúdos digitais e eventos ao vivo.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		background: linear-gradient(135deg, #2D2D2D 0%, #1A1A1A 100%);
		position: relative;
		color: white;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: start;
	}

	.section-header {
		margin-bottom: 3rem;
	}

	.section-title {
		color: white;
	}

	.section-subtitle {
		color: rgba(255, 255, 255, 0.8);
	}

	.about-features {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.about-feature {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 1rem;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
		border: 1px solid rgba(255, 90, 61, 0.2);
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
	}

	.about-feature:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
		background: rgba(255, 255, 255, 0.08);
	}

	.feature-icon-large {
		width: 4rem;
		height: 4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--gradient-primary);
		border-radius: 1rem;
		flex-shrink: 0;
		color: white;
	}

	.feature-content h3 {
		font-size: 1.25rem;
		font-weight: 700;
		color: white;
		margin-bottom: 0.5rem;
	}

	.feature-content p {
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
	}

	.about-visual {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.stat-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2rem 1.5rem;
		border-radius: 1rem;
		text-align: center;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
		border: 1px solid rgba(255, 90, 61, 0.2);
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
	}

	.stat-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
	}

	.stat-card.highlight {
		background: var(--gradient-primary);
		color: white;
	}

	.stat-number {
		font-size: 2.5rem;
		font-weight: 900;
		color: var(--primary-coral);
		display: block;
		margin-bottom: 0.5rem;
		line-height: 1;
	}

	.stat-card.highlight .stat-number {
		color: white;
	}

	.stat-label {
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.7);
		font-weight: 500;
	}

	.stat-card.highlight .stat-label {
		color: rgba(255, 255, 255, 0.9);
	}

	.concept-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2rem;
		border-radius: 1.5rem;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 90, 61, 0.2);
		position: relative;
		overflow: hidden;
		backdrop-filter: blur(10px);
	}

	.concept-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: var(--gradient-primary);
	}

	.concept-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.concept-icon {
		color: var(--primary-coral);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.concept-header h4 {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: var(--primary-coral);
		text-transform: uppercase;
	}

	.concept-content h3 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: white;
	}

	.concept-content p {
		line-height: 1.6;
		margin-bottom: 1rem;
		color: rgba(255, 255, 255, 0.7);
	}

	.concept-content p:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 768px) {
		.about-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.about-feature {
			flex-direction: column;
			text-align: center;
			padding: 2rem 1.5rem;
		}

		.stats-grid {
			grid-template-columns: 1fr;
		}

		.concept-card {
			padding: 1.5rem;
		}
	}
</style>