---

<footer class="footer">
	<div class="container">
		<div class="footer-content">
			<div class="footer-brand">
				<div class="footer-logo">
					<div class="logo-icon">
						<span class="logo-text">Media Lounge</span>
						<span class="logo-subtitle">P7 Criativo</span>
					</div>
				</div>
				<p class="footer-description">
					Hub de conteúdo digital e inovação no coração de Belo Horizonte. 
					Parceria 4 Nexus + P7 Criativo para transformar suas ideias em conteúdo profissional.
				</p>
				<div class="partnership">
					<span class="partnership-text">Uma parceria</span>
					<div class="partners">
						<span class="partner">4 Nexus</span>
						<span class="plus">+</span>
						<span class="partner">P7 Criativo</span>
					</div>
				</div>
			</div>

			<div class="footer-links">
				<div class="link-group">
					<h4>Navegação</h4>
					<ul>
						<li><a href="#sobre">Sobre</a></li>
						<li><a href="#servicos">Serviços</a></li>
						<li><a href="#planos">Planos</a></li>
						<li><a href="#contato">Contato</a></li>
					</ul>
				</div>

				<div class="link-group">
					<h4>Serviços</h4>
					<ul>
						<li><a href="#servicos">Estúdio Completo</a></li>
						<li><a href="#servicos">Gravação Profissional</a></li>
						<li><a href="#servicos">Edição de Vídeo</a></li>
						<li><a href="#servicos">Suporte Técnico</a></li>
					</ul>
				</div>

				<div class="link-group">
					<h4>Conteúdo</h4>
					<ul>
						<li>Podcasts</li>
						<li>Videocasts</li>
						<li>Cursos Online</li>
						<li>Entrevistas</li>
						<li>Conteúdo Corporativo</li>
					</ul>
				</div>
			</div>

			<div class="footer-cta">
				<div class="cta-box">
					<h4>Pronto para começar?</h4>
					<p>Transforme suas ideias em conteúdo profissional</p>
					<a href="#contato" class="btn btn-primary footer-button">
						Falar Conosco
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>
				</div>
				
				<div class="location-info">
					<div class="location-item">
						<div class="location-icon">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M21 10C21 17 12 23 12 23S3 17 3 10C3 5.02944 7.02944 1 12 1C16.9706 1 21 5.02944 21 10Z" stroke="currentColor" stroke-width="2"/>
								<circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>
							</svg>
						</div>
						<div class="location-text">
							<strong>P7 Criativo</strong>
							<span>24º andar - Centro de BH</span>
						</div>
					</div>
					<div class="location-item">
						<div class="location-icon">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
								<polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<div class="location-text">
							<strong>Início</strong>
							<span>Junho de 2025</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="footer-bottom">
			<div class="footer-bottom-content">
				<div class="copyright">
					<p>&copy; 2025 Media Lounge P7 Criativo. Todos os direitos reservados.</p>
					<p>Uma parceria <strong>4 Nexus</strong> + <strong>P7 Criativo</strong></p>
				</div>
				<div class="footer-badge">
					<span class="badge-text">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2L13.09 8.26L22 9L17 14L18.18 21L12 17.77L5.82 21L7 14L2 9L8.91 8.26L12 2Z" fill="currentColor"/>
						</svg>
						Promoção de Inauguração
					</span>
				</div>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: linear-gradient(135deg, var(--dark-gray), var(--black));
		color: white;
		padding: 5rem 0 0;
	}

	.footer-content {
		display: grid;
		grid-template-columns: 2fr 2fr 1fr;
		gap: 4rem;
		margin-bottom: 4rem;
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.footer-logo .logo-icon {
		display: flex;
		flex-direction: column;
		line-height: 1.2;
	}

	.logo-text {
		font-size: 2rem;
		font-weight: 900;
		color: var(--primary-coral);
		letter-spacing: -0.025em;
	}

	.logo-subtitle {
		font-size: 0.875rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.7);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-top: -0.25rem;
	}

	.footer-description {
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.8);
		margin: 0;
		font-size: 0.95rem;
	}

	.partnership {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.partnership-text {
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.6);
	}

	.partners {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.partner {
		font-weight: 700;
		color: var(--primary-coral);
		font-size: 0.95rem;
	}

	.plus {
		color: var(--secondary-yellow);
		font-weight: 700;
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.5rem;
	}

	.link-group h4 {
		font-size: 1.125rem;
		font-weight: 700;
		color: white;
		margin-bottom: 1.25rem;
	}

	.link-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.link-group ul li {
		color: rgba(255, 255, 255, 0.7);
		transition: color 0.3s ease;
		cursor: pointer;
		font-size: 0.875rem;
	}

	.link-group ul li:hover {
		color: var(--primary-coral);
	}

	.link-group ul li a {
		color: inherit;
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.link-group ul li a:hover {
		color: var(--primary-coral);
	}

	.footer-cta {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.cta-box {
		background: rgba(255, 90, 61, 0.1);
		padding: 1.5rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 90, 61, 0.2);
		text-align: center;
	}

	.cta-box h4 {
		font-size: 1.25rem;
		font-weight: 700;
		color: white;
		margin-bottom: 0.5rem;
	}

	.cta-box p {
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 1.25rem;
		font-size: 0.875rem;
	}

	.footer-button {
		padding: 0.75rem 1.5rem;
		font-size: 0.875rem;
	}

	.location-info {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.location-item {
		display: flex;
		gap: 0.75rem;
		align-items: flex-start;
	}

	.location-icon {
		color: var(--primary-coral);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.location-text {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.location-text strong {
		color: white;
		font-weight: 600;
		font-size: 0.875rem;
	}

	.location-text span {
		color: rgba(255, 255, 255, 0.7);
		font-size: 0.75rem;
	}

	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem 0;
	}

	.footer-bottom-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.copyright {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.copyright p {
		margin: 0;
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.875rem;
	}

	.copyright strong {
		color: var(--primary-coral);
	}

	.footer-badge {
		background: var(--gradient-primary);
		padding: 0.5rem 1rem;
		border-radius: 1.25rem;
		animation: pulse 2s infinite;
	}

	.badge-text {
		font-size: 0.75rem;
		font-weight: 600;
		color: white;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		.footer {
			padding: 4rem 0 0;
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			margin-bottom: 2.5rem;
		}

		.footer-links {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.footer-bottom-content {
			flex-direction: column;
			gap: 1.25rem;
			text-align: center;
		}

		.copyright {
			align-items: center;
		}
	}
</style>