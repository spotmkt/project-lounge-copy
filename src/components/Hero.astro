<section class="hero">
	<div class="container">
		<div class="hero-content">
			<div class="hero-text">
				<div class="hero-badge">
					<span class="badge-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2L13.09 8.26L22 9L17 14L18.18 21L12 17.77L5.82 21L7 14L2 9L8.91 8.26L12 2Z" fill="currentColor"/>
						</svg>
					</span>
					<span>Promoção de Inauguração - Vagas Limitadas!</span>
				</div>
				
				<h1 class="hero-title">
					Media Lounge<br>
					<span class="gradient-text">P7 Criativo + 4Nexus</span>
				</h1>
				
				<p class="hero-subtitle">
					Um hub de conteúdo digital e inovação no coração de Belo Horizonte! 
					Transforme suas ideias em conteúdo profissional com estrutura, técnica e inovação.
				</p>

				<div class="hero-features">
					<div class="feature-grid">
						<div class="feature-item">
							<div class="feature-icon">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
									<circle cx="8" cy="10" r="2" stroke="currentColor" stroke-width="2"/>
								</svg>
							</div>
							<span>Estúdio Completo</span>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M23 7L16 12L23 17V7Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									<rect x="1" y="5" width="15" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
									<circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
								</svg>
							</div>
							<span>3 Câmeras Simultâneas</span>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
									<path d="M12 1V3M12 21V23M4.22 4.22L5.64 5.64M18.36 18.36L19.78 19.78M1 12H3M21 12H23M4.22 19.78L5.64 18.36M18.36 5.64L19.78 4.22" stroke="currentColor" stroke-width="2"/>
									<circle cx="12" cy="12" r="2" fill="currentColor"/>
								</svg>
							</div>
							<span>Iluminação LED Profissional</span>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f75b3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"></circle><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"></path></svg>							</div>
							<span>Áudio Alta Qualidade</span>
						</div>
					</div>
				</div>

				<div class="hero-cta">
					<a href="#planos" class="btn btn-primary btn-lg">
						<span>Ver Planos Promocionais</span>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>
					<a href="#sobre" class="btn btn-secondary">Saiba Mais</a>
				</div>
			</div>

			<div class="hero-visual">
				<div class="hero-image-container">
					<img src="/images/IMG_6397.jpg" alt="Estúdio Media Lounge P7 Criativo" class="hero-image" />
					<div class="image-overlay">
						<div class="overlay-info">
							<div class="location-badge">24º Andar - P7 Criativo</div>
							<div class="stats-overlay">
								<div class="stat-overlay">
									<div class="stat-number">3</div>
									<div class="stat-label">CÂMERAS</div>
								</div>
								<div class="stat-overlay">
									<div class="stat-number">4K</div>
									<div class="stat-label">QUALIDADE</div>
								</div>
								<div class="stat-overlay">
									<div class="stat-number">LED</div>
									<div class="stat-label">ILUMINAÇÃO</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="hero-background">
		<div class="bg-gradient"></div>
		<div class="bg-pattern"></div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-top: 5rem;
		overflow: hidden;
		background: white;
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
		position: relative;
		z-index: 2;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--gradient-primary);
		color: white;
		padding: 0.75rem 1.5rem;
		border-radius: 2rem;
		font-size: 0.875rem;
		font-weight: 600;
		margin-bottom: 2rem;
		animation: pulse 2s infinite;
		box-shadow: var(--shadow-lg);
	}

	@keyframes pulse {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.05); }
	}

	.badge-icon {
		font-size: 1rem;
		display: flex;
		align-items: center;
	}

	.hero-title {
		font-size: 3.5rem;
		font-weight: 900;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		color: var(--black);
		letter-spacing: -0.02em;
	}

	.hero-subtitle {
		font-size: 1.25rem;
		line-height: 1.6;
		color: var(--medium-gray);
		margin-bottom: 3rem;
		max-width: 90%;
	}

	.hero-features {
		margin-bottom: 3rem;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.feature-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem;
		background: rgba(255, 90, 61, 0.05);
		border-radius: 0.75rem;
		border: 1px solid rgba(255, 90, 61, 0.1);
		transition: all 0.2s ease;
	}

	.feature-item:hover {
		background: rgba(255, 90, 61, 0.08);
		transform: translateY(-2px);
	}

	.feature-icon {
		color: var(--primary-coral);
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.feature-item span {
		font-weight: 500;
		color: var(--dark-gray);
		font-size: 0.875rem;
	}

	.hero-cta {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.btn-lg {
		padding: 1.25rem 2rem;
		font-size: 1.125rem;
		font-weight: 700;
	}

	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-image-container {
		position: relative;
		width: 100%;
		max-width: 600px;
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
		transform: rotate(3deg);
		transition: all 0.3s ease;
	}

	.hero-image-container:hover {
		transform: rotate(0deg) scale(1.05);
	}

	.hero-image {
		width: 100%;
		max-height: 580px;
		object-fit: cover;
		display: block;
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			135deg,
			rgba(0, 0, 0, 0.1) 0%,
			rgba(0, 0, 0, 0.3) 50%,
			rgba(0, 0, 0, 0.8) 100%
		);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2rem;
		opacity: 0;
		transition: all 0.3s ease;
	}

	.hero-image-container:hover .image-overlay {
		opacity: 1;
	}

	.overlay-info {
		color: white;
	}

	.location-badge {
		background: rgba(255, 90, 61, 0.9);
		color: white;
		padding: 0.5rem 1rem;
		border-radius: 1rem;
		font-size: 0.875rem;
		font-weight: 700;
		display: inline-block;
		margin-bottom: 1.5rem;
		backdrop-filter: blur(10px);
	}

	.stats-overlay {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
	}

	.stat-overlay {
		text-align: center;
		flex: 1;
	}

	.stat-overlay .stat-number {
		display: block;
		font-size: 1.5rem;
		font-weight: 900;
		color: white;
		line-height: 1;
		margin-bottom: 0.25rem;
	}

	.stat-overlay .stat-label {
		font-size: 0.625rem;
		color: rgba(255, 255, 255, 0.8);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
	}

	.hero-background {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 1;
		pointer-events: none;
	}

	.bg-gradient {
		position: absolute;
		top: 0;
		right: 0;
		width: 50%;
		height: 90%;
		background: linear-gradient(135deg, rgba(255, 90, 61, 0.08), rgba(255, 138, 61, 0.05));
		border-radius: 0 0 0 6rem;
	}

	.bg-pattern {
		position: absolute;
		top: 20%;
		right: 10%;
		width: 20rem;
		height: 20rem;
		background: radial-gradient(circle, rgba(255, 90, 61, 0.1) 1px, transparent 1px);
		background-size: 1.25rem 1.25rem;
		opacity: 0.4;
		border-radius: 50%;
	}

	@media (max-width: 768px) {
		.hero {
			padding-top: 6rem;
		}

		.hero-content {
			grid-template-columns: 1fr;
			gap: 3rem;
			text-align: center;
		}

		.hero-title {
			font-size: 2.5rem;
		}

		.hero-subtitle {
			font-size: 1.125rem;
			max-width: 100%;
		}

		.feature-grid {
			grid-template-columns: 1fr;
		}

		.hero-cta {
			flex-direction: column;
			align-items: stretch;
		}

		.hero-image-container {
			transform: none;
			max-width: 100%;
			margin-bottom: 1rem;
		}

		.hero-image {
			height: 300px;
		}

		.image-overlay {
			opacity: 1;
			background: linear-gradient(
				transparent 0%,
				rgba(0, 0, 0, 0.8) 70%
			);
		}

		.bg-gradient {
			width: 100%;
			border-radius: 0;
		}

		.bg-pattern {
			width: 15rem;
			height: 15rem;
		}
	}
</style>